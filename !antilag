local Lighting = game:GetService("Lighting")

-- 1. Immediate Lighting Change
Lighting.GlobalShadows = false
for _, effect in ipairs(Lighting:GetChildren()) do
    if effect:IsA("PostEffect") or effect:IsA("SunRaysEffect") then
        effect.Enabled = false 
    end
end

-- 2. Simplified Cleanup Function
local function cleanWorkspace()
    for _, item in ipairs(workspace:GetChildren()) do
        -- Skip actual players
        if game.Players:GetPlayerFromCharacter(item) then continue end
        
        -- Remove everything else that matches the list
        if item:IsA("Beam") or item:IsA("Trail") or item:IsA("Explosion") or 
           item:IsA("Tool") or item:IsA("Accessory") or 
          (item:IsA("Model") and item:FindFirstChildOfClass("Humanoid")) then
            item:Destroy()
        end
    end
end

-- 3. Basic Loop
while true do
    cleanWorkspace()
    task.wait(10)
end

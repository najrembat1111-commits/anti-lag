-- Wait for game load
if not game:IsLoaded() then game.Loaded:Wait() end

local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

-- 1. FIX THE ERROR: Instead of deleting SunRays, we just disable them.
-- This keeps CycleController happy because the object still exists.
local function silenceLighting()
    for _, effect in ipairs(Lighting:GetChildren()) do
        -- Check for SunRays, Bloom, Blur, etc.
        if effect:IsA("PostEffect") or effect:IsA("SunRaysEffect") then
            effect.Enabled = false -- GPU stops rendering it, but script doesn't crash
        end
    end
    -- Massive FPS boost: Turn off shadows
    Lighting.GlobalShadows = false
end

-- 2. CLEAN WORKSPACE: Remove physical lag (Beams, Tools, etc.)
local function cleanWorkspace()
    for _, item in ipairs(workspace:GetChildren()) do
        -- Skip actual players
        if Players:GetPlayerFromCharacter(item) then continue end
        
        -- Delete things that don't have scripts attached (safe to remove)
        if item:IsA("Beam") or item:IsA("Trail") or item:IsA("Explosion") then
            item:Destroy()
        elseif item:IsA("Tool") or item:IsA("Accessory") then
            -- These are usually dropped items or laggy hats
            item:Destroy()
        elseif item:IsA("Model") and item:FindFirstChildOfClass("Humanoid") then
            -- Removes NPCs/Corpses
            item:Destroy()
        end
    end
end

-- Run once for lighting
silenceLighting()

-- Run every 10 seconds for workspace cleanup
task.spawn(function()
    while true do
        pcall(cleanWorkspace)
        task.wait(10) 
    end
end)
